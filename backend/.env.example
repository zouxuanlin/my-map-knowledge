# 服务器配置
PORT=3000
NODE_ENV=development

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# PostgreSQL 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=my_map_knowledge
DB_USER=postgres
DB_PASSWORD=postgres

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AI 配置 (可选)
OPENAI_API_KEY=
CLAUDE_API_KEY=

# 前端地址 (CORS)
FRONTEND_URL=http://localhost:5173
